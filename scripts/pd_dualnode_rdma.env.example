# Source this file before running scripts if you want to override defaults.
#
# Example:
#   source scripts/pd_dualnode_rdma.env.example
#   bash scripts/run_pd_dualnode_rdma.sh amd0 probe

export LOCAL_HOST_ALIAS=amd0
export REMOTE_HOST_ALIAS=amd1

export LOCAL_HOST_IP=45.76.230.97
export REMOTE_HOST_IP=144.202.52.73

export DOCKER_IMAGE=rocm/vllm-dev:nightly
export CONTAINER_NAME=pd-lmcache

export MODEL_PATH=Qwen/Qwen3-8B
export SERVED_MODEL=Qwen3-8B-Instruct

# amd0 defaults follow docs/server_topology.md: GPU3 <-> bnxt_re0.
export PREFILL_GPU_INDEX=3
export PREFILL_RDMA_DEVICE=bnxt_re0

# amd1 keeps the same default shape but should be confirmed on the remote host.
export DECODER_GPU_INDEX=3
export DECODER_RDMA_DEVICE=bnxt_re0

export UCX_TLS_RDMA=rc,cuda_copy,cuda_ipc,self,sm
export UCX_SOCKADDR_TLS_PRIORITY=rdmacm

export LMCACHE_SERVER_L1_SIZE_GB=64
export LOCAL_CPU_SIZE_GB=32
export REMOTE_SERDE=naive

export LMCACHE_PIP_SPEC=lmcache==0.4.2
export NIXL_PIP_SPEC=nixl==1.0.0
